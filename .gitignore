# =============================================================================
# Auto-WIP — .gitignore
# =============================================================================

# --- Credentials & secrets (NEVER commit) ------------------------------------
.env
.env.local
.env.*.local
credentials.ini
secrets.json
# Contains plaintext DB passwords
SCHEMA.md

# --- Financial / proprietary data --------------------------------------------
# Nicole's 40 historical Excel override files
Data-from-Nicole/
# Recorded meeting files
meetings/
# Generated PDF/MD status reports (business-sensitive)
Status-Reports/

# --- Excel / Office binary files ---------------------------------------------
*.xltm
*.xlsm
*.xlsx
*.xlsb
*.docx
*.pdf
original/

# --- VM workbooks (binary, large, may embed credentials) ---------------------
vm/

# --- Crystal Reports ---------------------------------------------------------
vp/

# --- Python build artifacts --------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# --- Excel-era scripts (Windows COM automation — no longer needed) -----------
session-notes/
vba_source/
vba_source_569p/

# --- OS artifacts ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Editor artifacts --------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
